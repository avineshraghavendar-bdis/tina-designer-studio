# REQUIRED after your custom domain is live and DNS is connected.
# Set this to the exact URL users visit (no trailing slash).
# Example: https://tinadesignerstudio.com  OR  https://www.tinadesignerstudio.com
NEXT_PUBLIC_SITE_URL=

# If NEXT_PUBLIC_SITE_URL is empty, Vercel auto-uses the deployment URL for
# canonicals, sitemap, and Open Graph during preview/production builds.

# Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification code
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Google Analytics 4 — already configured in src/components/seo/GoogleTags.jsx
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-Y1LC0YL8X6

# EmailJS (Contact form)
# Get Public Key from: EmailJS → Account → General → API Keys → Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_rss1hmh
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_ax4maxh
